#!/usr/bin/env bash
# Bump HITT_BUILD_VERSION in hitt/hitt.sh (UTC YYYYMMDD-NN) and sync the README build line under the title.
# Runs only when hitt/hitt.sh is staged for this commit.
# Disable for one commit: SKIP_HITT_VERSION_HOOK=1 git commit ...
set -euo pipefail
[[ "${SKIP_HITT_VERSION_HOOK:-0}" == "1" ]] && exit 0

ROOT=$(git rev-parse --show-toplevel)
FILE="${ROOT}/hitt/hitt.sh"
README="${ROOT}/hitt/README.md"
[[ -f "${FILE}" ]] || exit 0

if git diff --cached --quiet -- hitt/hitt.sh; then
  exit 0
fi

line=$(grep -m1 -E '^HITT_BUILD_VERSION=' "${FILE}" || true)
line=${line//$'\r'/}
[[ -n "${line}" ]] || {
  echo "pre-commit: missing HITT_BUILD_VERSION= line in hitt/hitt.sh" >&2
  exit 1
}

val=""
if [[ "${line}" =~ ^HITT_BUILD_VERSION=\"([0-9]{8}-[0-9]{1,2})\"$ ]]; then
  val="${BASH_REMATCH[1]}"
elif [[ "${line}" =~ ^HITT_BUILD_VERSION=\'([0-9]{8}-[0-9]{1,2})\'$ ]]; then
  val="${BASH_REMATCH[1]}"
fi
if [[ -z "${val}" ]]; then
  echo "pre-commit: could not parse HITT_BUILD_VERSION from: ${line}" >&2
  exit 1
fi

prev_d="${val%-*}"
prev_n="${val#*-}"
today=$(date -u +%Y%m%d)

if [[ "${prev_d}" < "${today}" ]]; then
  n=1
elif [[ "${prev_d}" == "${today}" ]]; then
  n=$((10#${prev_n} + 1))
else
  n=1
fi

if (( n < 1 || n > 99 )); then
  echo "pre-commit: HITT_BUILD_VERSION daily counter out of range 01-99 (got ${n})" >&2
  exit 1
fi

newv=$(printf '%s-%02d' "${today}" "${n}")
tmp="${FILE}.precommit.$$"
while IFS= read -r l || [[ -n "${l}" ]]; do
  l=${l//$'\r'/}
  if [[ "${l}" =~ ^HITT_BUILD_VERSION= ]]; then
    printf '%s\n' "HITT_BUILD_VERSION=\"${newv}\""
  else
    printf '%s\n' "${l}"
  fi
done < "${FILE}" > "${tmp}"
mv -f "${tmp}" "${FILE}"
git add "${FILE}"

if [[ -f "${README}" ]]; then
  rtmp="${README}.precommit.$$"
  exec 3< "${README}"
  if IFS= read -r title_line <&3; then
    second_line=""
    IFS= read -r second_line <&3 || true
    # README after title: one line **Latest build `YYYYMMDD-NN`** (strip legacy ## Build and duplicate banners).
    # Use $'..' so backticks are literal in the ERE; escaped \` does not match a backtick under bash [[ =~ ]].
    readme_latest_re=$'^\*\*Latest[[:space:]]+build[[:space:]]+`[0-9]{8}-[0-9]{1,2}`\*\*[[:space:]]*$'
    readme_hash_re=$'^##[[:space:]]+Build[[:space:]]+`[0-9]{8}-[0-9]{1,2}`[[:space:]]*$'
    readme_build_out="**Latest build \`${newv}\`**"
    {
      printf '%s\n' "${title_line}"
      printf '%s\n' "${readme_build_out}"
      if [[ -n "${second_line}" ]] && [[ ! "${second_line}" =~ ${readme_latest_re} ]] && [[ ! "${second_line}" =~ ${readme_hash_re} ]]; then
        printf '%s\n' "${second_line}"
      fi
      while IFS= read -r rest <&3 || [[ -n "${rest}" ]]; do
        if [[ "${rest}" =~ ${readme_latest_re} ]] || [[ "${rest}" =~ ${readme_hash_re} ]]; then
          continue
        fi
        printf '%s\n' "${rest}"
      done
    } > "${rtmp}"
    mv -f "${rtmp}" "${README}"
    git add "${README}"
  else
    echo "pre-commit: warning: ${README} is empty; skipping build header sync" >&2
  fi
  exec 3<&-
fi

exit 0
